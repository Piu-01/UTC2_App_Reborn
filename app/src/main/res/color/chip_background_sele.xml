<?xml version="1.0" encoding="utf-8"?>
<!--
    chip_background_selector.xml
    Đặt trong: res/color/chip_background_selector.xml
    Dùng cho app:chipBackgroundColor của Chip filter.

    - checked (selected) → đen
    - unchecked (default) → trắng
-->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:color="#000000" android:state_checked="true"/>
    <item android:color="#FFFFFF"/>
</selector>
