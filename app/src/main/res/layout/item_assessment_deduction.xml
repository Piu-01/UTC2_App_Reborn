<?xml version="1.0" encoding="utf-8"?>
<!--
    item_assessment_deduction.xml
    Dòng trừ điểm:
      [Nội dung (màu đỏ)] [Điểm trừ] [Dropdown chọn mức trừ]
    Background hơi đỏ nhạt để phân biệt với tiêu chí thường.
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <!-- Divider đỏ nhạt -->
    <View
        android:layout_width="match_parent"
        android:layout_height="0.5dp"
        android:background="#FFCCCC"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp"
        android:gravity="center_vertical"
        android:minHeight="48dp"
        android:background="#FFF5F5">

        <!-- Nội dung trừ điểm -->
        <TextView
            android:id="@+id/tvDeductionTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textSize="13sp"
            android:textColor="#CC0000"
            android:lineSpacingExtra="2dp"
            android:layout_marginEnd="8dp"/>

        <!-- Mức trừ tối đa -->
        <TextView
            android:id="@+id/tvMaxDeduction"
            android:layout_width="44dp"
            android:layout_height="wrap_content"
            android:textSize="13sp"
            android:textColor="#CC0000"
            android:textStyle="bold"
            android:gravity="center"/>

        <!-- Dropdown chọn mức trừ -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilDeductionScore"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
            android:layout_width="64dp"
            android:layout_height="wrap_content"
            app:boxStrokeColor="#CC0000"
            app:hintTextColor="#CC0000"
            app:boxBackgroundColor="#FFF5F5">

            <com.google.android.material.textfield.MaterialAutoCompleteTextView
                android:id="@+id/actvDeductionScore"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="13sp"
                android:textColor="#CC0000"
                android:textStyle="bold"
                android:gravity="center"
                android:inputType="none"/>

        </com.google.android.material.textfield.TextInputLayout>

    </LinearLayout>

</LinearLayout>