<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:background="#F1F5F9"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- ══ HEADER ══ -->
        <LinearLayout
            android:orientation="horizontal"
            android:padding="16dp"
            android:gravity="center_vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <TextView
                android:id="@+id/btnBack"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="←"
                android:textSize="22sp"
                android:textColor="#000000"
                android:padding="4dp"
                android:layout_marginEnd="10dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Kí túc xá"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="#000000"/>
        </LinearLayout>

        <!-- ══ TAB ══ -->
        <LinearLayout
            android:orientation="horizontal"
            android:background="@drawable/bg_tab_container"
            android:layout_margin="16dp"
            android:padding="4dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <TextView
                android:id="@+id/tabDangKy"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="Đăng ký"
                android:gravity="center"
                android:padding="10dp"
                android:textColor="#FFFFFF"
                android:background="@drawable/bg_tab_selected"/>

            <TextView
                android:id="@+id/tabTraPhong"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="Tra phòng"
                android:gravity="center"
                android:padding="10dp"
                android:textColor="#000000"/>
        </LinearLayout>

        <!-- ══ TÌM KIẾM ══ -->
        <EditText
            android:id="@+id/searchBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Tìm phòng..."
            android:textColor="#000000"
            android:layout_marginHorizontal="16dp"
            android:background="@drawable/bg_search"
            android:padding="12dp"
            android:drawableStart="@drawable/ic_search"
            android:drawablePadding="8dp"
            android:inputType="text"/>

        <!-- ══ FILTER ══ -->
        <LinearLayout
            android:orientation="horizontal"
            android:layout_margin="16dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <TextView
                android:id="@+id/btnToa"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="Tòa nhà ▾"
                android:textColor="#000000"
                android:gravity="center"
                android:padding="10dp"
                android:background="@drawable/bg_search"/>

            <TextView
                android:id="@+id/btnGia"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="Giá tiền ▾"
                android:textColor="#000000"
                android:gravity="center"
                android:padding="10dp"
                android:layout_marginHorizontal="8dp"
                android:background="@drawable/bg_search"/>

            <TextView
                android:id="@+id/btnLoai"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="Loại phòng ▾"
                android:textColor="#000000"
                android:gravity="center"
                android:padding="10dp"
                android:background="@drawable/bg_search"/>
        </LinearLayout>

        <!-- ══ DANH SÁCH PHÒNG (RecyclerView) ══ -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvRooms"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:nestedScrollingEnabled="false"/>

        <!-- ══ PHÒNG ĐÃ CHỌN ══ -->
        <LinearLayout
            android:id="@+id/layoutSelected"
            android:orientation="vertical"
            android:visibility="gone"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <!-- CARD thông tin phòng -->
            <com.google.android.material.card.MaterialCardView
                xmlns:app="http://schemas.android.com/apk/res-auto"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="16dp"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp"
                app:strokeColor="#000000"
                app:strokeWidth="2dp">

                <LinearLayout
                    android:orientation="vertical"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <!-- HEADER: "Phòng đã chọn:" + icon mũi tên -->
                    <LinearLayout
                        android:orientation="horizontal"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:paddingHorizontal="16dp"
                        android:paddingTop="16dp"
                        android:paddingBottom="14dp"
                        android:gravity="center_vertical">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="wrap_content"
                            android:text="Phòng đã chọn:"
                            android:textColor="#FF0000"
                            android:textSize="16sp"
                            android:textStyle="bold"/>

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/ic_arrow_down"
                            android:tint="#666666"
                            android:scaleType="centerInside"/>
                    </LinearLayout>

                    <!-- DIVIDER: có padding 2 bên, không chạm cạnh khung -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginHorizontal="16dp"
                        android:background="#E0E0E0"/>

                    <!-- NỘI DUNG phòng -->
                    <LinearLayout
                        android:orientation="vertical"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:paddingHorizontal="16dp"
                        android:paddingTop="14dp"
                        android:paddingBottom="16dp">

                        <!-- Tên phòng to, đậm -->
                        <TextView
                            android:id="@+id/txtRoomInfo"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="#000000"
                            android:textSize="22sp"
                            android:textStyle="bold"/>

                        <!-- Info: số người + giá -->
                        <TextView
                            android:id="@+id/txtRoomSubInfo"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="#555555"
                            android:textSize="14sp"
                            android:layout_marginTop="4dp"/>

                        <!-- DIVIDER có padding 2 bên -->
                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:layout_marginTop="12dp"
                            android:background="#E0E0E0"/>

                        <!-- Tổng tiền -->
                        <TextView
                            android:id="@+id/txtTotal"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="#555555"
                            android:textSize="14sp"
                            android:layout_marginTop="10dp"/>

                    </LinearLayout>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!--
                NÚT HỦY: nằm NGOÀI card, tách rời.
                Dùng TextView thay Button để tránh Material override màu tím.
                background="@drawable/bg_button_cancel" → đen + bo góc lớn.
            -->
            <TextView
                android:id="@+id/btnCancel"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="16dp"
                android:text="Hủy đăng ký"
                android:background="@drawable/bg_button_cancel"
                android:textColor="#FFFFFF"
                android:textAllCaps="false"
                android:textSize="15sp"
                android:textStyle="bold"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true"/>

        </LinearLayout>

    </LinearLayout>

</ScrollView>