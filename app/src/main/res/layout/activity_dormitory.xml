<?xml version="1.0" encoding="utf-8"?>
<!--
    Layout duy nhất cho toàn bộ màn hình Kí túc xá.
    Bao gồm:
      - Header (← + tiêu đề)   : luôn hiển thị
      - Tab bar (Đăng ký / Tra phòng) : luôn hiển thị
      - pageDangKy    : nội dung trang Đăng ký   (VISIBLE / GONE)
      - pageTraPhong  : nội dung trang Tra phòng  (VISIBLE / GONE)
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:background="#F1F5F9"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- ══ HEADER (cố định trên cùng) ══ -->
    <LinearLayout
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <TextView
            android:id="@+id/btnBack"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="←"
            android:textSize="22sp"
            android:textColor="#000000"
            android:padding="4dp"
            android:layout_marginEnd="10dp"
            android:clickable="true"
            android:focusable="true"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Kí túc xá"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#000000"/>
    </LinearLayout>

    <!-- ══ TAB BAR (cố định, không cuộn) ══ -->
    <LinearLayout
        android:orientation="horizontal"
        android:background="@drawable/bg_tab_container"
        android:layout_marginHorizontal="16dp"
        android:layout_marginBottom="8dp"
        android:padding="4dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <TextView
            android:id="@+id/tabDangKy"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:text="Đăng ký"
            android:gravity="center"
            android:padding="10dp"
            android:textColor="#FFFFFF"
            android:background="@drawable/bg_tab_selected"
            android:clickable="true"
            android:focusable="true"/>

        <TextView
            android:id="@+id/tabTraPhong"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:text="Tra phòng"
            android:gravity="center"
            android:padding="10dp"
            android:textColor="#000000"
            android:clickable="true"
            android:focusable="true"/>
    </LinearLayout>

    <!-- ══ CONTENT AREA (cuộn được) ══ -->
    <!-- Dùng FrameLayout để chồng 2 page lên nhau, show/hide bằng VISIBLE/GONE -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <!-- ══════════════════════════════════════════════════
                 PAGE 1: ĐĂNG KÝ
                 ══════════════════════════════════════════════════ -->
            <LinearLayout
                android:id="@+id/pageDangKy"
                android:orientation="vertical"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:visibility="visible">

                <!-- Tìm kiếm -->
                <EditText
                    android:id="@+id/searchBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Tìm phòng..."
                    android:textColor="#000000"
                    android:layout_marginHorizontal="16dp"
                    android:background="@drawable/bg_search"
                    android:padding="12dp"
                    android:drawableStart="@drawable/ic_search"
                    android:drawablePadding="8dp"
                    android:inputType="text"/>

                <!-- Filter -->
                <LinearLayout
                    android:orientation="horizontal"
                    android:layout_margin="16dp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <TextView
                        android:id="@+id/btnToa"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:text="Tòa nhà ▾"
                        android:textColor="#000000"
                        android:gravity="center"
                        android:padding="10dp"
                        android:background="@drawable/bg_search"/>

                    <TextView
                        android:id="@+id/btnGia"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:text="Giá tiền ▾"
                        android:textColor="#000000"
                        android:gravity="center"
                        android:padding="10dp"
                        android:layout_marginHorizontal="8dp"
                        android:background="@drawable/bg_search"/>

                    <TextView
                        android:id="@+id/btnLoai"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:text="Loại phòng ▾"
                        android:textColor="#000000"
                        android:gravity="center"
                        android:padding="10dp"
                        android:background="@drawable/bg_search"/>
                </LinearLayout>

                <!-- Danh sách phòng -->
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvRooms"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:nestedScrollingEnabled="false"/>

                <!-- Phòng đã chọn -->
                <LinearLayout
                    android:id="@+id/layoutSelected"
                    android:orientation="vertical"
                    android:visibility="gone"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginHorizontal="16dp"
                        android:layout_marginTop="16dp"
                        app:cardCornerRadius="20dp"
                        app:cardElevation="0dp"
                        app:strokeColor="#000000"
                        app:strokeWidth="2dp">

                        <LinearLayout
                            android:orientation="vertical"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content">

                            <LinearLayout
                                android:orientation="horizontal"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:paddingHorizontal="16dp"
                                android:paddingTop="16dp"
                                android:paddingBottom="14dp"
                                android:gravity="center_vertical">

                                <TextView
                                    android:layout_width="0dp"
                                    android:layout_weight="1"
                                    android:layout_height="wrap_content"
                                    android:text="Phòng đã chọn:"
                                    android:textColor="#FF0000"
                                    android:textSize="16sp"
                                    android:textStyle="bold"/>

                                <ImageView
                                    android:layout_width="24dp"
                                    android:layout_height="24dp"
                                    android:src="@drawable/ic_arrow_down"
                                    android:tint="#666666"
                                    android:scaleType="centerInside"/>
                            </LinearLayout>

                            <View
                                android:layout_width="match_parent"
                                android:layout_height="1dp"
                                android:layout_marginHorizontal="16dp"
                                android:background="#E0E0E0"/>

                            <LinearLayout
                                android:orientation="vertical"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:paddingHorizontal="16dp"
                                android:paddingTop="14dp"
                                android:paddingBottom="16dp">

                                <TextView
                                    android:id="@+id/txtRoomInfo"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:textColor="#000000"
                                    android:textSize="22sp"
                                    android:textStyle="bold"/>

                                <TextView
                                    android:id="@+id/txtRoomSubInfo"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:textColor="#555555"
                                    android:textSize="14sp"
                                    android:layout_marginTop="4dp"/>

                                <View
                                    android:layout_width="match_parent"
                                    android:layout_height="1dp"
                                    android:layout_marginTop="12dp"
                                    android:background="#E0E0E0"/>

                                <TextView
                                    android:id="@+id/txtTotal"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:textColor="#555555"
                                    android:textSize="14sp"
                                    android:layout_marginTop="10dp"/>
                            </LinearLayout>
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <TextView
                        android:id="@+id/btnCancel"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:layout_marginHorizontal="16dp"
                        android:layout_marginTop="12dp"
                        android:layout_marginBottom="16dp"
                        android:text="Hủy đăng ký"
                        android:background="@drawable/bg_button_cancel"
                        android:textColor="#FFFFFF"
                        android:textAllCaps="false"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:gravity="center"
                        android:clickable="true"
                        android:focusable="true"/>
                </LinearLayout>

            </LinearLayout>
            <!-- END pageDangKy -->

            <!-- ══════════════════════════════════════════════════
                 PAGE 2: TRA PHÒNG
                 ══════════════════════════════════════════════════ -->
            <LinearLayout
                android:id="@+id/pageTraPhong"
                android:orientation="vertical"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:visibility="gone">

                <!-- Dropdown chọn phòng + chọn tòa -->
                <LinearLayout
                    android:orientation="horizontal"
                    android:layout_marginHorizontal="16dp"
                    android:layout_marginTop="8dp"
                    android:layout_marginBottom="12dp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <TextView
                        android:id="@+id/btnChonPhong"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:text="Chọn phòng  ▾"
                        android:textColor="#000000"
                        android:textSize="14sp"
                        android:gravity="center"
                        android:padding="12dp"
                        android:background="@drawable/bg_search"
                        android:clickable="true"
                        android:focusable="true"/>

                    <TextView
                        android:id="@+id/btnChonToa"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:text="Chọn tòa  ▾"
                        android:textColor="#000000"
                        android:textSize="14sp"
                        android:gravity="center"
                        android:padding="12dp"
                        android:layout_marginStart="10dp"
                        android:background="@drawable/bg_search"
                        android:clickable="true"
                        android:focusable="true"/>
                </LinearLayout>

                <!-- Nút tìm kiếm -->
                <TextView
                    android:id="@+id/btnTimKiem"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginHorizontal="16dp"
                    android:layout_marginBottom="16dp"
                    android:text="Tìm kiếm"
                    android:textColor="#FFFFFF"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:background="@drawable/bg_button_cancel"
                    android:clickable="true"
                    android:focusable="true"/>

                <!-- Card thông tin phòng -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardRoomInfo"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="16dp"
                    android:layout_marginBottom="14dp"
                    android:visibility="gone"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="0dp"
                    app:strokeColor="#000000"
                    app:strokeWidth="2dp"
                    app:cardBackgroundColor="#FFFFFF">

                    <LinearLayout
                        android:orientation="vertical"
                        android:padding="16dp"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">

                        <!-- Row: avatar + tên + trạng thái -->
                        <LinearLayout
                            android:orientation="horizontal"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:layout_marginBottom="12dp">

                            <com.google.android.material.card.MaterialCardView
                                android:layout_width="52dp"
                                android:layout_height="52dp"
                                android:layout_marginEnd="12dp"
                                app:cardCornerRadius="26dp"
                                app:cardElevation="0dp"
                                app:strokeColor="#000000"
                                app:strokeWidth="2dp"
                                app:cardBackgroundColor="#F0F0F0">

                                <androidx.appcompat.widget.AppCompatImageView
                                    android:layout_width="match_parent"
                                    android:layout_height="match_parent"
                                    android:src="@drawable/ic_user"
                                    android:scaleType="centerInside"
                                    android:padding="10dp"/>
                            </com.google.android.material.card.MaterialCardView>

                            <LinearLayout
                                android:orientation="vertical"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content">

                                <TextView
                                    android:id="@+id/tvRoomName"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:textSize="18sp"
                                    android:textStyle="bold"
                                    android:textColor="#000000"/>

                                <TextView
                                    android:id="@+id/tvRoomStatus"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:textSize="13sp"
                                    android:textColor="#666666"
                                    android:layout_marginTop="2dp"/>
                            </LinearLayout>
                        </LinearLayout>

                        <!-- Loại phòng -->
                        <LinearLayout
                            android:orientation="horizontal"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:layout_marginBottom="6dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text=" "
                                android:textSize="14sp"
                                android:layout_marginEnd="6dp"/>

                            <TextView
                                android:id="@+id/tvRoomType"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textSize="14sp"
                                android:textColor="#333333"/>
                        </LinearLayout>

                        <!-- Sức chứa -->
                        <LinearLayout
                            android:orientation="horizontal"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:layout_marginBottom="6dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text=" "
                                android:textSize="14sp"
                                android:layout_marginEnd="6dp"/>

                            <TextView
                                android:id="@+id/tvCapacity"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textSize="14sp"
                                android:textColor="#333333"/>
                        </LinearLayout>

                        <!-- Giá -->
                        <LinearLayout
                            android:orientation="horizontal"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:layout_marginBottom="14dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text=" "
                                android:textSize="14sp"
                                android:layout_marginEnd="6dp"/>

                            <TextView
                                android:id="@+id/tvPrice"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textSize="14sp"
                                android:textColor="#333333"/>
                        </LinearLayout>

                        <!-- Progress bar -->
                        <ProgressBar
                            android:id="@+id/progressOccupancy"
                            style="@android:style/Widget.ProgressBar.Horizontal"
                            android:layout_width="match_parent"
                            android:layout_height="10dp"
                            android:layout_marginBottom="6dp"
                            android:max="100"
                            android:progressTint="#000000"
                            android:progressBackgroundTint="#E0E0E0"/>

                        <LinearLayout
                            android:orientation="horizontal"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="12dp">

                            <TextView
                                android:id="@+id/tvCurrentCount"
                                android:layout_width="0dp"
                                android:layout_weight="1"
                                android:layout_height="wrap_content"
                                android:textSize="13sp"
                                android:textColor="#FF0000"
                                android:textStyle="bold"/>

                            <TextView
                                android:id="@+id/tvCapacityLabel"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textSize="13sp"
                                android:textColor="#555555"/>
                        </LinearLayout>

                        <!-- Badge trạng thái với icon drawable -->
                        <LinearLayout
                            android:orientation="horizontal"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical">

                            <ImageView
                                android:id="@+id/ivStatusIcon"
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:layout_marginEnd="6dp"
                                android:src="@drawable/ic_status_check"
                                android:contentDescription="Trạng thái"/>

                            <TextView
                                android:id="@+id/tvStatusBadge"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textSize="14sp"
                                android:textStyle="bold"/>
                        </LinearLayout>

                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Card sinh viên đang ở -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardOccupants"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="16dp"
                    android:layout_marginBottom="24dp"
                    android:visibility="gone"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="0dp"
                    app:strokeColor="#000000"
                    app:strokeWidth="2dp"
                    app:cardBackgroundColor="#FFFFFF">

                    <LinearLayout
                        android:orientation="vertical"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Sinh viên đang ở"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:textColor="#000000"
                            android:padding="16dp"/>

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:layout_marginHorizontal="16dp"
                            android:background="#E0E0E0"/>

                        <androidx.recyclerview.widget.RecyclerView
                            android:id="@+id/rvOccupants"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:nestedScrollingEnabled="false"
                            android:padding="8dp"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>
            <!-- END pageTraPhong -->

        </FrameLayout>
    </ScrollView>

</LinearLayout>
