<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?attr/selectableItemBackground"
    app:cardBackgroundColor="@color/invoice_card_bg"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:id="@+id/tvInvoiceID"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/invoice_text_id"
            android:textStyle="bold"
            android:textSize="14sp"
            tools:text="Mã hóa đơn: UTC2_2026_01" />

        <TextView
            android:id="@+id/tvInvoiceDate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:textColor="@color/text_gray"
            android:textSize="12sp"
            tools:text="Ngày thanh toán: 10/04/2026" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginVertical="10dp"
            android:background="@color/invoice_divider" />

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentStart="true"
                android:layout_centerInParent="true"
                android:text="Thành công"
                android:textColor="@color/invoice_text_id"
                android:textSize="11sp"
                android:textStyle="italic" />

            <TextView
                android:id="@+id/tvInvoiceAmount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:textColor="@color/invoice_text_amount"
                android:textSize="17sp"
                android:textStyle="bold"
                tools:text="2.500.000 VND" />
        </RelativeLayout>
    </LinearLayout>
</androidx.cardview.widget.CardView>