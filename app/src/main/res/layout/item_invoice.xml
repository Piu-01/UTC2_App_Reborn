<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    app:cardBackgroundColor="#F1F8E9"
    app:cardCornerRadius="12dp"
    app:cardElevation="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:id="@+id/tvInvoiceID"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#2E7D32"
            android:textStyle="bold"
            android:textSize="14sp"
            tools:text="Mã hóa đơn: UTC2_2026_01" />

        <TextView
            android:id="@+id/tvInvoiceDate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:textColor="#757575"
            android:textSize="12sp"
            tools:text="Ngày thanh toán: 10/04/2026" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginVertical="10dp"
            android:background="#C8E6C9" />

        <TextView
            android:id="@+id/tvInvoiceAmount"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="end"
            android:textColor="#1B5E20"
            android:textSize="17sp"
            android:textStyle="bold"
            tools:text=" 2.500.000 VND" />
    </LinearLayout>
</androidx.cardview.widget.CardView>