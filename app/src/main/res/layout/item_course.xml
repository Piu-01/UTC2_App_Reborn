<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="12dp"
    android:layout_marginHorizontal="16dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="0dp"
    app:strokeColor="#000000"
    app:strokeWidth="1.5dp"
    app:cardBackgroundColor="#FFFFFF">

    <!--
        Outer horizontal: cột trái (thông tin) | cột phải (nút Đăng ký căn giữa dọc)
        gravity="center_vertical" trên outer đảm bảo nút luôn nằm giữa theo chiều cao
        của toàn bộ nội dung bên trái.
    -->
    <LinearLayout
        android:padding="16dp"
        android:orientation="horizontal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical">

        <!-- ══ CỘT TRÁI: tất cả nội dung ══ -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Tên môn học -->
            <TextView
                android:id="@+id/txtCourseTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Tên học phần"
                android:textStyle="bold"
                android:textSize="16sp"
                android:textColor="#000000"/>

            <!-- DIVIDER dưới tên – full width trong cột trái -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="10dp"
                android:layout_marginBottom="10dp"
                android:background="#EEEEEE"/>

            <!-- Mã môn -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="4dp">
                <TextView
                    android:id="@+id/txtMaMonHoc"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Mã môn: IT0588485"
                    android:textSize="13sp"/>
            </LinearLayout>

            <!-- Số tín chỉ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="4dp">
                <TextView
                    android:id="@+id/txtSoTinChi"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Số tín chỉ: 3"
                    android:textSize="13sp"/>
            </LinearLayout>

            <!-- Giảng viên -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="4dp">
                <TextView
                    android:id="@+id/txtGiangVien"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Giảng viên: Trần Thị Dung"
                    android:textSize="13sp"/>
            </LinearLayout>

            <!-- Thời gian -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="4dp">

                <TextView
                    android:id="@+id/txtThoiGian"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Thời gian: T2, T4 (7:00-9:30)"
                    android:textSize="13sp"/>
            </LinearLayout>

            <!-- Phòng -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="4dp">

                <TextView
                    android:id="@+id/txtPhong"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Phòng: A201"
                    android:textSize="13sp"/>
            </LinearLayout>

            <!-- Số tiết học -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="4dp">

                <TextView
                    android:id="@+id/txtSoTiet"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Số tiết: 45"
                    android:textSize="13sp"/>
            </LinearLayout>

            <!-- Ngày bắt đầu - Kết thúc (single line) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/txtNgayHoc"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Bắt đầu: 27/09/2026 - 23/12/2026"
                    android:textSize="13sp"
                    android:singleLine="true"
                    android:ellipsize="none"
                    android:scrollHorizontally="true"/>
            </LinearLayout>

            <!-- DIVIDER trước sĩ số – full width trong cột trái -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="10dp"
                android:layout_marginBottom="10dp"
                android:background="#EEEEEE"/>

            <!-- Hàng "Hiện tại : X    X / Y" -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="4dp">
                <TextView
                    android:id="@+id/txtSiSoCurrent"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:text="Hiện tại : 0"
                    android:textSize="12sp"
                    android:textColor="#E53935"
                    android:textStyle="bold"/>
                <TextView
                    android:id="@+id/txtSiSoRatio"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0 / 60"
                    android:textSize="12sp"
                    android:textColor="#555555"/>
            </LinearLayout>

            <!-- Progress bar sĩ số – full width, màu đen -->
            <ProgressBar
                android:id="@+id/progressSiSo"
                style="@android:style/Widget.ProgressBar.Horizontal"
                android:layout_width="match_parent"
                android:layout_height="10dp"
                android:max="60"
                android:progress="30"
                android:progressTint="#000000"
                android:progressBackgroundTint="#EEEEEE"
                android:layout_marginBottom="6dp"/>

            <!-- Trạng thái: icon ic_status_check / ic_status_x + text -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">
                <ImageView
                    android:id="@+id/icTrangThai"
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:src="@drawable/ic_status_check"
                    android:layout_marginEnd="6dp"
                    android:scaleType="centerInside"/>
                <TextView
                    android:id="@+id/txtTrangThai"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Trạng thái: Còn chỗ"
                    android:textSize="12sp"
                    android:textColor="#2E7D32"/>
            </LinearLayout>

        </LinearLayout>
        <!-- ══ END CỘT TRÁI ══ -->

        <!-- ══ CỘT PHẢI: Nút Đăng ký – tự căn giữa dọc nhờ gravity outer ══ -->
        <TextView
            android:id="@+id/btnRegisterCourse"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:layout_marginStart="12dp"
            android:text="Đăng ký"
            android:textAllCaps="false"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:background="@drawable/bg_button_black"
            android:gravity="center"
            android:paddingHorizontal="16dp"
            android:clickable="true"
            android:focusable="true"/>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>