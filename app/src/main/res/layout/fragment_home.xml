<?xml version="1.0" encoding="utf-8"?>
<!--
    fragment_home.xml — 3 BUG FIXES
    ──────────────────────────────────────────────────────────────
    Fix 1 — Status bar overlap (Android 15 edge-to-edge):
      Root là LinearLayout(vertical). Con đầu tiên là View spacer
      với height=0dp, được set bằng Java = chiều cao status bar thực.
      CoordinatorLayout bắt đầu ngay dưới status bar. ✓

    Fix 2 — Profile bar bị che khi scroll:
      Toolbar dùng android:elevation="8dp" để luôn nằm trên
      ImageView parallax. CollapsingToolbarLayout đặt thêm
      app:toolbarId="@id/toolbar" để mapping chính xác. ✓

    Fix 3 — Bỏ iv_add_btn (icon thừa cạnh tên):
      Đã xóa hoàn toàn khỏi layout. ✓
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/white">

    <!--
        FIX 1: Status bar spacer
        height=0dp ban đầu, được set trong HomeFragment.java
        bằng WindowInsets để bằng đúng chiều cao status bar thực.
        Background #1E1E1E khớp với màu toolbar collapsed.
    -->
    <View
        android:id="@+id/status_bar_spacer"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:background="@color/toolbar_collapsed_bg" />

    <!-- CoordinatorLayout chiếm toàn bộ phần còn lại -->
    <androidx.coordinatorlayout.widget.CoordinatorLayout
        android:id="@+id/coordinator_layout"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <!-- ══════════════════════════════════════════════════
             APP BAR — Collapsible Hero Header
             ══════════════════════════════════════════════════ -->
        <com.google.android.material.appbar.AppBarLayout
            android:id="@+id/app_bar_layout"
            android:layout_width="match_parent"
            android:layout_height="220dp"
            android:theme="@style/ThemeOverlay.AppCompat.Dark.ActionBar">

            <com.google.android.material.appbar.CollapsingToolbarLayout
                android:id="@+id/collapsing_toolbar"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                app:layout_scrollFlags="scroll|exitUntilCollapsed|snap"
                app:titleEnabled="false"
                app:toolbarId="@id/toolbar"
                app:contentScrim="@color/toolbar_collapsed_bg"
                app:statusBarScrim="@color/toolbar_collapsed_bg">

                <!-- Ảnh nền trường (parallax) -->
                <ImageView
                    android:id="@+id/iv_header"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    android:src="@drawable/pg_header_campus"
                    android:contentDescription="@string/cd_campus_header"
                    app:layout_collapseMode="parallax"
                    app:layout_collapseParallaxMultiplier="0.5" />

                <!-- Gradient overlay (làm tối vùng toolbar để text dễ đọc) -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/bg_header_gradient"
                    app:layout_collapseMode="parallax"
                    app:layout_collapseParallaxMultiplier="0.5" />

                <!--
                    FIX 2: Toolbar với elevation="8dp" đảm bảo luôn
                    nằm trên ImageView parallax, không bị che khi scroll.
                    app:layout_collapseMode="pin" = dính ở trên khi cuộn.
                    Không có layout_gravity → Toolbar ở TOP của AppBar.
                -->
                <androidx.appcompat.widget.Toolbar
                    android:id="@+id/toolbar"
                    android:layout_width="match_parent"
                    android:layout_height="?attr/actionBarSize"
                    android:elevation="8dp"
                    android:paddingStart="8dp"
                    android:paddingEnd="4dp"
                    app:layout_collapseMode="pin"
                    app:contentInsetStart="0dp"
                    app:contentInsetEnd="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <!-- ── LEFT: Avatar + Greeting + Name ─────────── -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">

                            <!-- Avatar bo tròn -->
                            <FrameLayout
                                android:id="@+id/iv_avatar"
                                android:layout_width="44dp"
                                android:layout_height="44dp"
                                android:background="@drawable/bg_avatar_circle"
                                android:clickable="true"
                                android:focusable="true"
                                android:foreground="?attr/selectableItemBackgroundBorderless">

                                <ImageView
                                    android:layout_width="26dp"
                                    android:layout_height="30dp"
                                    android:layout_gravity="center"
                                    android:contentDescription="@string/cd_avatar"
                                    android:src="@drawable/ic_user" />
                            </FrameLayout>

                            <!-- Greeting text -->
                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical"
                                android:layout_marginStart="10dp">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/greeting"
                                    android:textColor="#FFFFFF"
                                    android:textSize="11sp"
                                    android:alpha="0.85" />

                                <!--
                                    FIX 3: Đã XÓA iv_add_btn (icon thừa cạnh tên).
                                    Chỉ còn TextView tên — QR đã có nút riêng bên phải.
                                -->
                                <TextView
                                    android:id="@+id/tv_username"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/default_username"
                                    android:textColor="#FFFFFF"
                                    android:textStyle="bold"
                                    android:textSize="14sp"
                                    android:maxLines="1"
                                    android:ellipsize="end"
                                    android:maxWidth="150dp" />
                            </LinearLayout>
                        </LinearLayout>

                        <!-- ── RIGHT: 3 Icon Buttons ──────────────────── -->

                        <!-- Mã QR -->
                        <ImageButton
                            android:id="@+id/btn_qr"
                            android:layout_width="44dp"
                            android:layout_height="44dp"
                            android:src="@drawable/ic_qr_code"
                            android:background="?attr/selectableItemBackgroundBorderless"
                            android:padding="9dp"
                            android:scaleType="centerInside"
                            android:contentDescription="Mã QR sinh viên"
                            app:tint="#FFFFFF" />

                        <!-- Tìm kiếm -->
                        <ImageButton
                            android:id="@+id/btn_search"
                            android:layout_width="44dp"
                            android:layout_height="44dp"
                            android:src="@drawable/ic_search"
                            android:background="?attr/selectableItemBackgroundBorderless"
                            android:padding="9dp"
                            android:scaleType="centerInside"
                            android:contentDescription="Tìm kiếm"
                            app:tint="#FFFFFF" />

                        <!-- Thông báo -->
                        <ImageButton
                            android:id="@+id/btn_notification"
                            android:layout_width="44dp"
                            android:layout_height="44dp"
                            android:src="@drawable/ic_notification"
                            android:background="?attr/selectableItemBackgroundBorderless"
                            android:padding="9dp"
                            android:scaleType="centerInside"
                            android:contentDescription="Thông báo"
                            app:tint="#FFFFFF" />

                    </LinearLayout>
                </androidx.appcompat.widget.Toolbar>
            </com.google.android.material.appbar.CollapsingToolbarLayout>
        </com.google.android.material.appbar.AppBarLayout>

        <!-- ══════════════════════════════════════════════════
             SCROLLABLE CONTENT
             ══════════════════════════════════════════════════ -->
        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@color/white"
            android:fillViewport="true"
            android:overScrollMode="never"
            app:layout_behavior="@string/appbar_scrolling_view_behavior">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingBottom="16dp">

                <!-- ════════════════════════════════
                     Tính năng mở rộng (3×2 Grid)
                     ════════════════════════════════ -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/section_features"
                    android:textSize="17sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"
                    android:layout_marginStart="16dp"
                    android:layout_marginTop="18dp"
                    android:layout_marginBottom="10dp" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rv_features"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingStart="10dp"
                    android:paddingEnd="10dp"
                    android:clipToPadding="false"
                    android:nestedScrollingEnabled="false"
                    android:overScrollMode="never" />

                <!-- ════════════════════════════════
                     Campus Banner
                     ════════════════════════════════ -->
                <ImageView
                    android:id="@+id/iv_campus_banner"
                    android:layout_width="match_parent"
                    android:layout_height="220dp"
                    android:layout_marginTop="24dp"
                    android:scaleType="centerCrop"
                    android:src="@drawable/bg_campus_banner"
                    android:contentDescription="@string/cd_campus_banner" />

                <!-- ════════════════════════════════
                     Thông báo mới nhất
                     ════════════════════════════════ -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/section_news"
                    android:textSize="17sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"
                    android:layout_marginStart="16dp"
                    android:layout_marginTop="18dp"
                    android:layout_marginBottom="10dp" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rv_news"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:clipToPadding="false"
                    android:nestedScrollingEnabled="false"
                    android:overScrollMode="never" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_view_all_news"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginStart="16dp"
                    android:layout_marginEnd="16dp"
                    android:layout_marginTop="12dp"
                    android:layout_marginBottom="24dp"
                    android:text="Xem thêm thông báo trên web"
                    android:textSize="14sp"
                    android:textAllCaps="false"
                    android:textColor="@color/accent_yellow_dark"
                    app:strokeColor="@color/accent_yellow"
                    app:strokeWidth="1.5dp"
                    app:cornerRadius="24dp"
                    app:backgroundTint="@color/white" />

            </LinearLayout>
        </androidx.core.widget.NestedScrollView>

    </androidx.coordinatorlayout.widget.CoordinatorLayout>
</LinearLayout>