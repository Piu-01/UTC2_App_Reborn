<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="320dp"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_rounded_white"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="24dp"
    android:layout_gravity="center">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/title_payment_dialog"
        android:textColor="@color/dialog_title_blue"
        android:textSize="18sp"
        android:textStyle="bold"
        android:gravity="center" />

    <TextView
        android:id="@+id/tvDialogAmount"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:textColor="@color/amount_red"
        android:textSize="20sp"
        android:textStyle="bold"
        tools:text="10.509.368 VND" />

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginTop="12dp"
        android:background="@color/divider_gray" />

    <ImageView
        android:id="@+id/imgQrCode"
        android:layout_width="220dp"
        android:layout_height="220dp"
        android:layout_marginVertical="20dp"
        android:contentDescription="@string/desc_invoice_icon"
        android:scaleType="fitCenter"
        tools:src="@drawable/ic_user" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:text="@string/qr_instruction"
        android:textColor="@color/instruction_gray"
        android:textSize="13sp"
        android:lineSpacingExtra="2dp" />

    <Button
        android:id="@+id/btnConfirmPayment"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:layout_marginTop="20dp"
        app:backgroundTint="@color/success_green"
        android:text="@string/btn_confirm_paid"
        android:textColor="@color/white"
        android:textStyle="bold"
        app:cornerRadius="12dp" />

</LinearLayout>