<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="8dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_rounded_white"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical">

        <ImageView
            android:id="@+id/imgIcon"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:src="@drawable/ic_id_card"
            android:scaleType="fitCenter"
            android:contentDescription="@string/section_public_service" />

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp">

            <TextView
                android:id="@+id/txtTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/reissue_card_title"
                android:textColor="@color/black"
                android:textStyle="bold"
                android:textSize="17sp" />

            <TextView
                android:id="@+id/txtDate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_below="@id/txtTitle"
                android:layout_marginTop="2dp"
                android:text="@string/date_placeholder"
                android:textColor="#757575"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/txtStatus"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:layout_below="@id/txtDate"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_button_black"
                android:paddingHorizontal="12dp"
                android:text="@string/status_approved"
                android:textColor="@color/white"
                android:textSize="11sp"
                app:drawableStartCompat="@drawable/ic_clock_2"
                android:drawablePadding="6dp"
                android:gravity="center"
                app:drawableTint="@color/white"/>

            <TextView
                android:id="@+id/btnDetail"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:layout_alignParentEnd="true"
                android:layout_alignBottom="@id/txtStatus"
                android:background="@drawable/bg_rounded_white"
                android:paddingHorizontal="12dp"
                android:text="@string/view_detail"
                android:textColor="@color/black"
                android:textSize="11sp"
                android:textStyle="bold"
                android:gravity="center" />
        </RelativeLayout>
    </LinearLayout>
</androidx.cardview.widget.CardView>