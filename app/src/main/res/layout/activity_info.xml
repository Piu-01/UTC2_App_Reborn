<?xml version="1.0" encoding="utf-8"?>

<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- HEADER WITH BACK BUTTON -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="#FFFFFF"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            tools:ignore="RtlSymmetry">

            <ImageView
                android:id="@+id/btnBack"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_centerVertical="true"
                android:src="@drawable/ic_arrow_left"
                android:contentDescription="@string/back"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true"
                android:text="@string/profile_title"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#000000"/>
        </RelativeLayout>

        <!-- CONTENT CONTAINER -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="8dp"
            android:paddingBottom="24dp"
            tools:ignore="RtlSymmetry">

            <!-- STUDENT CARD IMAGE -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                app:cardElevation="4dp"
                app:cardCornerRadius="12dp">

                <ImageView
                    android:id="@+id/imgStudentCard"
                    android:layout_width="match_parent"
                    android:layout_height="200dp"
                    android:src="@drawable/ic_user"
                    android:scaleType="fitCenter"
                    android:adjustViewBounds="true"
                    android:contentDescription="@string/student_card"/>
            </androidx.cardview.widget.CardView>

            <!-- NOI DANG KY KHAI SINH -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingTop="12dp"
                android:paddingBottom="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/birth_place"
                    android:textSize="13sp"
                    android:textColor="#666666"
                    android:paddingBottom="4dp"/>

                <TextView
                    android:id="@+id/tvBirthPlace"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Xã gió đó, Tỉnh Đồng Thuận"
                    android:textSize="15sp"
                    android:textColor="#000000"
                    tools:ignore="HardcodedText"/>
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#E0E0E0"/>

            <!-- SO CCCD/CMND -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingTop="12dp"
                android:paddingBottom="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/cccd"
                    android:textSize="13sp"
                    android:textColor="#666666"
                    android:paddingBottom="4dp"/>

                <TextView
                    android:id="@+id/tvCCCD"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="083385896945785884"
                    android:textSize="15sp"
                    android:textColor="#000000"
                    tools:ignore="HardcodedText"/>
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#E0E0E0"/>

            <!-- NOI THUONG TRU -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingTop="12dp"
                android:paddingBottom="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/permanent_address"
                    android:textSize="13sp"
                    android:textColor="#666666"
                    android:paddingBottom="4dp"/>

                <TextView
                    android:id="@+id/tvAddress"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/default_address"
                    android:textSize="15sp"
                    android:textColor="#000000"/>
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#E0E0E0"/>

            <!-- NOI TAM TRU -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingTop="12dp"
                android:paddingBottom="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Nơi tạm trú:"
                    android:textSize="13sp"
                    android:textColor="#666666"
                    android:paddingBottom="4dp"
                    tools:ignore="HardcodedText"/>

                <TextView
                    android:id="@+id/tvTempAddress"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/default_address"
                    android:textSize="15sp"
                    android:textColor="#000000"/>
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#E0E0E0"/>

            <!-- NOI O HIEN TAI -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingTop="12dp"
                android:paddingBottom="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Nơi ở hiện tại:"
                    android:textSize="13sp"
                    android:textColor="#666666"
                    android:paddingBottom="4dp"
                    tools:ignore="HardcodedText"/>

                <TextView
                    android:id="@+id/tvCurrentAddress"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/default_address"
                    android:textSize="15sp"
                    android:textColor="#000000"/>
            </LinearLayout>

            <!-- BUTTONS SECTION - DÙNG MaterialButton -->

            <!-- Button Chuong trinh dao tao -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnTrainingProgram"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="@string/training_program"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:textStyle="bold"
                android:layout_marginBottom="12dp"
                app:backgroundTint="#2196F3"
                app:cornerRadius="8dp"
                app:elevation="2dp"/>

            <!-- Button Ho tro 24/7 -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSupport"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="@string/title_support"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:textStyle="bold"
                android:layout_marginBottom="12dp"
                app:backgroundTint="#4CAF50"
                app:cornerRadius="8dp"
                app:elevation="2dp"/>

            <!-- Button Thoat dang nhap -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnLogout"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="@string/logout"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:textStyle="bold"
                app:backgroundTint="#F44336"
                app:cornerRadius="8dp"
                app:elevation="2dp"/>

        </LinearLayout>

    </LinearLayout>

</ScrollView>