<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="12dp"
        android:paddingBottom="12dp"
        android:gravity="center_vertical">

        <!-- Tên môn + mã + TC — layout_weight khiến cột này co giãn -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="3"
            android:orientation="vertical"
            android:paddingEnd="8dp">

            <TextView
                android:id="@+id/tv_course_name"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Lập trình Java"
                android:textSize="13sp"
                android:textColor="#000000"
                android:textStyle="bold"
                android:maxLines="2"
                android:ellipsize="end"/>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="3dp">

                <TextView
                    android:id="@+id/tv_course_code"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="IT3040"
                    android:textSize="11sp"
                    android:textColor="#9E9E9E"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=" · "
                    android:textSize="11sp"
                    android:textColor="#9E9E9E"/>

                <TextView
                    android:id="@+id/tv_credits"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="3 TC"
                    android:textSize="11sp"
                    android:textColor="#9E9E9E"/>

            </LinearLayout>

        </LinearLayout>

        <!-- GK -->
        <TextView
            android:id="@+id/tv_midterm"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="8.5"
            android:textSize="13sp"
            android:textColor="#424242"
            android:gravity="center"/>

        <!-- CK -->
        <TextView
            android:id="@+id/tv_final"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="7.8"
            android:textSize="13sp"
            android:textColor="#424242"
            android:gravity="center"/>

        <!-- Điểm + chữ -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <TextView
                android:id="@+id/tv_gpa"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="3.48"
                android:textSize="13sp"
                android:textColor="#000000"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/tv_letter_grade"
                android:layout_width="30dp"
                android:layout_height="20dp"
                android:text="B+"
                android:textSize="10sp"
                android:textStyle="bold"
                android:gravity="center"
                android:layout_marginTop="3dp"
                android:background="@drawable/bg_grade_pass"
                android:textColor="#FFFFFF"/>

        </LinearLayout>

    </LinearLayout>

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#F0F0F0"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"/>

</LinearLayout>
