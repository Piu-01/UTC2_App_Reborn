<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/card_warning_item"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="0dp"
    app:cardBackgroundColor="#FFFFFF">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Title — paddingEnd dành chỗ cho badge ⚠ -->
            <TextView
                android:id="@+id/tv_warning_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Điểm thi không đạt"
                android:textSize="15sp"
                android:textColor="#000000"
                android:textStyle="bold"
                android:paddingEnd="32dp"
                android:maxLines="2"
                android:ellipsize="end"/>

            <TextView
                android:id="@+id/tv_warning_subtitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=""
                android:textSize="12sp"
                android:textColor="#757575"
                android:layout_marginTop="4dp"
                android:visibility="gone"/>

            <TextView
                android:id="@+id/tv_warning_date"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="18/04/2026"
                android:textSize="11sp"
                android:textColor="#9E9E9E"
                android:layout_marginTop="8dp"/>

        </LinearLayout>

        <!-- Icon badge — chỉ NGHIÊM TRỌNG -->
        <ImageView
            android:id="@+id/iv_serious_badge"
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:src="@drawable/ic_warning_triangle"
            android:layout_gravity="top|end"
            android:layout_marginTop="16dp"
            android:layout_marginEnd="16dp"
            android:visibility="gone"
            android:contentDescription="Nghiêm trọng"/>

    </FrameLayout>
</androidx.cardview.widget.CardView>
