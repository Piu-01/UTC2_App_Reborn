<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET"/>

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:theme="@style/Theme.UTC2AppReborn">

        <!-- LOGIN -->
        <activity
            android:name=".ui.login.LoginActivity"
            android:exported="true">

            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>
        </activity>

        <!-- FORGOT PASSWORD -->
        <activity
            android:name=".ui.login.ForgotPasswordActivity"
            android:exported="false"/>

        <!-- MAIN -->
        <activity
            android:name=".ui.main.MainActivity"
            android:exported="false"/>

        <!-- PROFILE -->
        <activity
            android:name=".ui.profile.ProfileActivity"
            android:exported="false"/>

        <!-- TRAINING PROGRAM -->
        <activity
            android:name=".ui.profile.TrainingProgramActivity"
            android:exported="false"/>

        <!-- SUPPORT -->
        <activity
            android:name=".ui.profile.SupportActivity"
            android:exported="false"/>

        <!-- ================= TUITION ================= -->

        <!-- Trang chọn học phí -->
        <activity
            android:name=".ui.tuition.TuitionActivity"
            android:exported="false"/>

        <!-- Trang xem học phí -->
        <activity
            android:name=".ui.tuition.TuitionResultActivity"
            android:exported="false"/>

        <!-- Trang thanh toán -->
        <!--<activity
            android:name=".ui.tuition.PaymentActivity"
            android:exported="false"/>
-->
    </application>

</manifest>